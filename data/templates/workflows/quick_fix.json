{
  "id": "quick_fix_v1",
  "name": "Quick Fix (Scout → Coder → Verify)",
  "description": "Lightweight pipeline for simple bug fixes and small changes. Scout finds the code, Coder fixes it, Verifier confirms.",
  "version": 1,
  "metadata": {
    "created_at": "2026-02-16T00:00:00Z",
    "author": "vetka-system",
    "phase": "153",
    "complexity_range": [1, 3],
    "task_types": ["fix", "patch", "hotfix"]
  },
  "nodes": [
    {
      "id": "scout",
      "type": "agent",
      "label": "Scout (Find Code)",
      "position": { "x": 100, "y": 200 },
      "data": {
        "role": "scout",
        "description": "Quick scan: find target file + surrounding context",
        "outputs": ["relevant_files", "marker_map"]
      }
    },
    {
      "id": "coder",
      "type": "agent",
      "label": "Coder (Fix)",
      "position": { "x": 300, "y": 200 },
      "data": {
        "role": "coder",
        "description": "Apply the fix using Scout markers as rails",
        "outputs": ["code_changes"]
      }
    },
    {
      "id": "verifier",
      "type": "agent",
      "label": "Verifier (Check)",
      "position": { "x": 500, "y": 200 },
      "data": {
        "role": "verifier",
        "description": "Verify fix is correct: code present, logic sound, no regressions",
        "outputs": ["passed", "confidence", "issues"]
      }
    },
    {
      "id": "output",
      "type": "output",
      "label": "Result",
      "position": { "x": 700, "y": 200 },
      "data": {
        "description": "Final fix output"
      }
    }
  ],
  "edges": [
    { "id": "e-scout-coder", "source": "scout", "target": "coder" },
    { "id": "e-coder-verifier", "source": "coder", "target": "verifier" },
    { "id": "e-verifier-output", "source": "verifier", "target": "output" }
  ]
}
