{
  "id": "research_first_v1",
  "name": "Research First (Researcher → Architect → Coder → Verify)",
  "description": "For tasks involving unfamiliar libraries, APIs, or patterns. Web researcher gathers docs before Architect plans.",
  "version": 1,
  "metadata": {
    "created_at": "2026-02-16T00:00:00Z",
    "author": "vetka-system",
    "phase": "153",
    "complexity_range": [3, 7],
    "task_types": ["build", "integrate", "learn"]
  },
  "nodes": [
    {
      "id": "researcher",
      "type": "agent",
      "label": "Researcher (Web/Docs)",
      "position": { "x": 100, "y": 200 },
      "data": {
        "role": "researcher",
        "description": "Search Tavily/Context7 for library docs, API patterns, known issues",
        "outputs": ["web_sources", "api_patterns", "known_issues"]
      }
    },
    {
      "id": "architect",
      "type": "agent",
      "label": "Architect (Plan)",
      "position": { "x": 300, "y": 200 },
      "data": {
        "role": "architect",
        "description": "Plan implementation using research findings. Break into subtasks.",
        "outputs": ["subtasks", "task_breakdown"]
      }
    },
    {
      "id": "coder",
      "type": "agent",
      "label": "Coder (Implement)",
      "position": { "x": 500, "y": 200 },
      "data": {
        "role": "coder",
        "description": "Implement code using research context + architect plan",
