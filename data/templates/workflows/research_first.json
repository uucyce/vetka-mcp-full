      }
    },
    {
      "id": "verifier",
      "type": "agent",
      "label": "Verifier (Review)",
      "position": { "x": 700, "y": 200 },
      "data": {
        "role": "verifier",
        "description": "Verify implementation matches research findings and plan",
        "outputs": ["passed", "confidence", "issues"]
      }
    },
    {
      "id": "output",
      "type": "output",
      "label": "Result",
      "position": { "x": 900, "y": 200 },
      "data": {}
    }
  ],
  "edges": [
    { "id": "e-res-arch", "source": "researcher", "target": "architect" },
    { "id": "e-arch-coder", "source": "architect", "target": "coder" },
    { "id": "e-coder-ver", "source": "coder", "target": "verifier" },
