{
  "id": "g3_critic_coder_v1",
  "name": "G3 Pair (Critic + Coder)",
  "description": "Two-agent adversarial cooperation loop where Critic challenges and Coder revises until bounded acceptance.",
  "version": 1,
  "metadata": {
    "created_at": "2026-03-02T18:00:00Z",
    "updated_at": "2026-03-02T22:20:00Z",
    "author": "vetka-system",
    "preset": "dragon_silver",
    "task_types": ["g3", "critic", "critic_coder", "review_code", "pair"],
    "complexity_range": [2, 7],
    "template_family": "core_library",
    "pattern_source": "block.xyz g3 paper + dhanji/g3",
    "execution_contract": {
      "adversarial_roles": true,
      "max_review_rounds_default": 5,
      "hard_stop_on_budget_exhaustion": true
    }
  },
  "nodes": [
    {
      "id": "spec",
      "type": "task",
      "label": "Task Spec + Constraints",
      "position": { "x": 80, "y": 120 },
      "data": {
        "description": "Freeze scope, success criteria, and non-negotiable constraints before coding.",
        "outputs": ["spec_contract"]
      }
    },
    {
      "id": "critic",
      "type": "agent",
      "label": "Critic",
      "position": { "x": 300, "y": 120 },
      "data": {
        "role": "verifier",
        "description": "Produces attack-style review, failing cases, and concrete revision directives.",
        "outputs": ["critic_report", "required_fixes"]
      }
    },
    {
      "id": "coder",
      "type": "agent",
      "label": "Coder",
      "position": { "x": 520, "y": 120 },
      "data": {
        "role": "coder",
        "description": "Implements patch and addresses each critic directive with evidence.",
        "outputs": ["patch", "fix_log"]
      }
    },
    {
      "id": "acceptance_gate",
      "type": "condition",
      "label": "Acceptance Gate",
      "position": { "x": 740, "y": 120 },
      "data": {
        "condition": "all required fixes are closed and tests pass",
        "max_iterations": 5
      }
    },
    {
      "id": "budget_guard",
      "type": "condition",
      "label": "Budget Guard",
      "position": { "x": 940, "y": 120 },
      "data": {
        "condition": "review rounds <= max_review_rounds",
        "max_iterations": 5
      }
    },
    {
      "id": "final_verify",
      "type": "agent",
      "label": "Final Verify",
      "position": { "x": 1140, "y": 120 },
      "data": {
        "role": "verifier",
        "description": "Run final tests/lint and emit deterministic pass/fail outcome.",
        "outputs": ["passed", "issues"]
      }
    }
  ],
  "edges": [
    { "id": "e1", "source": "spec", "target": "critic", "type": "dataflow", "label": "spec_contract" },
    { "id": "e2", "source": "critic", "target": "coder", "type": "dataflow", "label": "required_fixes" },
    { "id": "e3", "source": "coder", "target": "acceptance_gate", "type": "structural", "label": "candidate_patch" },
    { "id": "e4", "source": "acceptance_gate", "target": "budget_guard", "type": "structural", "label": "review_state" },
    { "id": "e5", "source": "budget_guard", "target": "critic", "type": "feedback", "label": "iterate_if_needed" },
    { "id": "e6", "source": "acceptance_gate", "target": "final_verify", "type": "structural", "label": "accepted_patch" }
  ]
}
