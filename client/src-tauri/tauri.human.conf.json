{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VETKA CUT Review",
  "identifier": "ai.vetka.cut.review",
  "build": {
    "beforeDevCommand": "npm run dev:cut:human",
    "devUrl": "http://127.0.0.1:3011",
    "beforeBuildCommand": "npm run build:cut:human",
    "frontendDist": "../dist-cut-human"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VETKA CUT - Human Review",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:5001 ws://127.0.0.1:5001 http://localhost:5001 ws://localhost:5001 http://127.0.0.1:3011 ws://127.0.0.1:3011; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
