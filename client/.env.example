# VETKA Frontend Configuration
# Copy to .env.local for local development

# API Base URL (default: /api via Vite proxy)
# VITE_API_BASE=/api

# WebSocket URL (default: current origin via Vite proxy)
# VITE_SOCKET_URL=http://localhost:5001

# For production, set these to actual backend URLs:
# VITE_API_BASE=https://api.vetka.app/api
# VITE_SOCKET_URL=https://api.vetka.app
