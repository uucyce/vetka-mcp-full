{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact_media_window_contract_v1.schema.json",
  "title": "VETKA Artifact Media Window Contract V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "action",
    "target_window",
    "payload",
    "timestamp_ms"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "artifact_media_window_contract_v1"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[a-fA-F0-9-]{16,64}$"
    },
    "action": {
      "type": "string",
      "enum": [
        "open_media_window",
        "close_media_window",
        "toggle_fullscreen",
        "set_quality_scale",
        "sync_playback_state"
      ]
    },
    "target_window": {
      "type": "string",
      "enum": [
        "main",
        "detached"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "window_label": { "type": "string", "minLength": 1 },
        "fullscreen_enabled": { "type": "boolean" },
        "quality_scale": {
          "type": "string",
          "enum": ["full", "half", "quarter", "eighth", "sixteenth"]
        },
        "session_state": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "path",
            "current_time",
            "is_playing",
            "volume",
            "is_muted",
            "quality_scale",
            "playback_rate"
          ],
          "properties": {
            "schema_version": { "type": "string", "const": "artifact_media_session_state_v1" },
            "path": { "type": "string", "minLength": 1 },
            "current_time": { "type": "number", "minimum": 0 },
            "is_playing": { "type": "boolean" },
            "volume": { "type": "number", "minimum": 0, "maximum": 1 },
            "is_muted": { "type": "boolean" },
            "quality_scale": {
              "type": "string",
              "enum": ["full", "half", "quarter", "eighth", "sixteenth"]
            },
            "playback_rate": { "type": "number", "minimum": 0.25, "maximum": 8.0 }
          }
        }
      }
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "trace": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "action": { "const": "open_media_window" } } },
      "then": {
        "properties": {
          "payload": {
            "required": ["path"]
          }
        }
      }
    },
    {
      "if": { "properties": { "action": { "const": "set_quality_scale" } } },
      "then": {
        "properties": {
          "payload": {
            "required": ["quality_scale"]
          }
        }
      }
    },
    {
      "if": { "properties": { "action": { "const": "toggle_fullscreen" } } },
      "then": {
        "properties": {
          "payload": {
            "required": ["fullscreen_enabled"]
          }
        }
      }
    },
    {
      "if": { "properties": { "action": { "const": "sync_playback_state" } } },
      "then": {
        "properties": {
          "payload": {
            "required": ["session_state"]
          }
        }
      }
    }
  ]
}
