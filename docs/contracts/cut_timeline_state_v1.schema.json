{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_timeline_state_v1.schema.json",
  "title": "VETKA CUT Timeline State V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "timeline_id",
    "revision",
    "fps",
    "lanes",
    "selection",
    "view",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cut_timeline_state_v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "timeline_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "fps": {
      "type": "number",
      "minimum": 1,
      "maximum": 120
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lane_id", "lane_type", "clips"],
        "properties": {
          "lane_id": {"type": "string", "minLength": 1},
          "lane_type": {
            "type": "string",
            "enum": ["video_main", "audio_sync", "take_alt_y", "take_alt_z", "aux"]
          },
          "clips": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["clip_id", "record_id", "scene_id", "take_id", "start_sec", "duration_sec", "source_path"],
              "properties": {
                "clip_id": {"type": "string", "minLength": 1},
                "record_id": {"type": "string", "minLength": 1},
                "scene_id": {"type": "string", "minLength": 1},
                "take_id": {"type": "string", "minLength": 1},
                "start_sec": {"type": "number", "minimum": 0},
                "duration_sec": {"type": "number", "exclusiveMinimum": 0},
                "source_path": {"type": "string", "minLength": 1},
                "sync": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "properties": {
                    "method": {"type": "string"},
                    "offset_sec": {"type": "number"},
                    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
                    "applied_at": {"type": "string", "format": "date-time"},
                    "reference_path": {"type": "string"},
                    "source": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clip_ids": {"type": "array", "items": {"type": "string"}},
        "scene_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zoom", "scroll_sec"],
      "properties": {
        "zoom": {"type": "number", "exclusiveMinimum": 0},
        "scroll_sec": {"type": "number", "minimum": 0},
        "active_lane_id": {"type": "string"}
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sync_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["group_id", "source_path", "reference_path", "method", "offset_sec", "confidence"],
        "properties": {
          "group_id": {"type": "string", "minLength": 1},
          "source_path": {"type": "string", "minLength": 1},
          "reference_path": {"type": "string", "minLength": 1},
          "method": {"type": "string"},
          "offset_sec": {"type": "number"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "applied_at": {"type": ["string", "null"], "format": "date-time"}
        }
      }
    }
  }
}
