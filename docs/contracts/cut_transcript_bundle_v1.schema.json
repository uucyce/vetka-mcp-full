{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_transcript_bundle_v1.schema.json",
  "title": "VETKA CUT Transcript Bundle V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "revision",
    "items",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cut_transcript_bundle_v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "source_path",
          "transcript_normalized_json",
          "degraded_mode",
          "degraded_reason"
        ],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "source_path": { "type": "string", "minLength": 1 },
          "transcript_normalized_json": { "type": "object", "additionalProperties": true },
          "degraded_mode": { "type": "boolean" },
          "degraded_reason": { "type": "string" }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
