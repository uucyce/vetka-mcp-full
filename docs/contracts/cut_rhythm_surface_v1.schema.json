{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_rhythm_surface_v1.schema.json",
  "title": "VETKA CUT Rhythm Surface V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "music_path",
    "music_tempo_bpm",
    "scene_target_bpm",
    "bpm_delta",
    "rhythm_profile",
    "cut_density_per_min",
    "source_engine",
    "items",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cut_rhythm_surface_v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "music_path": {
      "type": "string",
      "minLength": 1
    },
    "music_tempo_bpm": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "scene_target_bpm": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "bpm_delta": {
      "type": ["number", "null"]
    },
    "rhythm_profile": {
      "type": "string",
      "minLength": 1
    },
    "cut_density_per_min": {
      "type": "number",
      "minimum": 0
    },
    "source_engine": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "start_sec",
          "end_sec",
          "label",
          "cue_type",
          "confidence",
          "energy",
          "target_bpm",
          "music_bpm",
          "bpm_delta",
          "recommendation"
        ],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "start_sec": { "type": "number", "minimum": 0 },
          "end_sec": { "type": "number", "minimum": 0 },
          "label": { "type": "string", "minLength": 1 },
          "cue_type": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "energy": { "type": "number", "minimum": 0, "maximum": 1 },
          "target_bpm": { "type": ["number", "null"], "minimum": 0 },
          "music_bpm": { "type": ["number", "null"], "minimum": 0 },
          "bpm_delta": { "type": ["number", "null"] },
          "recommendation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
