{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_mcp_job_v1.schema.json",
  "title": "VETKA CUT MCP Job V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "job_type",
    "state",
    "progress",
    "retry_count",
    "route_mode",
    "cancel_requested",
    "degraded_mode",
    "degraded_reason",
    "input",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cut_mcp_job_v1"
    },
    "job_id": {
      "type": "string",
      "minLength": 16
    },
    "job_type": {
      "type": "string",
      "enum": ["bootstrap", "scene_assembly", "timeline_init", "waveform_build", "transcript_normalize", "thumbnail_build", "audio_sync", "pause_slice", "timecode_sync"]
    },
    "state": {
      "type": "string",
      "enum": ["queued", "running", "partial", "done", "error", "cancelled"]
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "route_mode": {
      "type": "string",
      "enum": ["control", "background"]
    },
    "cancel_requested": {
      "type": "boolean"
    },
    "cancel_requested_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "degraded_mode": {
      "type": "boolean"
    },
    "degraded_reason": {
      "type": "string"
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "result": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "error": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
