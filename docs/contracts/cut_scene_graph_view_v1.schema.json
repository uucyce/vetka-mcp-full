{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_scene_graph_view_v1.schema.json",
  "title": "VETKA CUT Scene Graph View V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "graph_id",
    "nodes",
    "edges",
    "focus",
    "layout_hints",
    "crosslinks",
    "structural_subgraph",
    "overlay_edges",
    "dag_projection",
    "inspector",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cut_scene_graph_view_v1"
    },
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_id",
          "node_type",
          "visual_bucket",
          "label",
          "parent_id",
          "rank_hint",
          "selection_refs",
          "render_hints",
          "metadata"
        ],
        "properties": {
          "node_id": {"type": "string", "minLength": 1},
          "node_type": {"type": "string", "minLength": 1},
          "visual_bucket": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "parent_id": {"type": ["string", "null"]},
          "rank_hint": {"type": ["integer", "null"]},
          "selection_refs": {
            "type": "object",
            "additionalProperties": false,
            "required": ["clip_ids", "scene_ids", "source_paths"],
            "properties": {
              "clip_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "scene_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "source_paths": {"type": "array", "items": {"type": "string", "minLength": 1}}
            }
          },
          "render_hints": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "display_mode",
              "poster_url",
              "modality",
              "duration_sec",
              "marker_count",
              "sync_badge"
            ],
            "properties": {
              "display_mode": {"type": "string", "minLength": 1},
              "poster_url": {"type": ["string", "null"]},
              "modality": {"type": ["string", "null"]},
              "duration_sec": {"type": ["number", "null"]},
              "marker_count": {"type": "integer", "minimum": 0},
              "sync_badge": {"type": ["string", "null"]}
            }
          },
          "metadata": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "edge_id",
          "edge_type",
          "family",
          "source",
          "target",
          "weight",
          "visible_by_default"
        ],
        "properties": {
          "edge_id": {"type": "string", "minLength": 1},
          "edge_type": {"type": "string", "minLength": 1},
          "family": {"type": "string", "enum": ["structural", "intelligence"]},
          "source": {"type": "string", "minLength": 1},
          "target": {"type": "string", "minLength": 1},
          "weight": {"type": "number", "minimum": 0, "maximum": 1},
          "visible_by_default": {"type": "boolean"}
        }
      }
    },
    "focus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_clip_ids",
        "selected_scene_ids",
        "focused_node_ids",
        "anchor_node_id"
      ],
      "properties": {
        "selected_clip_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "selected_scene_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "focused_node_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "anchor_node_id": {
          "type": ["string", "null"]
        }
      }
    },
    "layout_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "structural_edge_types",
        "intelligence_edge_types",
        "primary_rank_edge_types"
      ],
      "properties": {
        "structural_edge_types": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "intelligence_edge_types": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "primary_rank_edge_types": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "crosslinks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "by_clip_id",
        "by_scene_id",
        "by_source_path"
      ],
      "properties": {
        "by_clip_id": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        },
        "by_scene_id": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        },
        "by_source_path": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "structural_subgraph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_ids",
        "edge_ids"
      ],
      "properties": {
        "node_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "edge_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "overlay_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "edge_id",
          "edge_type",
          "family",
          "source",
          "target",
          "weight",
          "visible_by_default"
        ],
        "properties": {
          "edge_id": {"type": "string", "minLength": 1},
          "edge_type": {"type": "string", "minLength": 1},
          "family": {"type": "string", "enum": ["structural", "intelligence"]},
          "source": {"type": "string", "minLength": 1},
          "target": {"type": "string", "minLength": 1},
          "weight": {"type": "number", "minimum": 0, "maximum": 1},
          "visible_by_default": {"type": "boolean"}
        }
      }
    },
    "dag_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "edges", "root_ids"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "type",
              "label",
              "status",
              "layer",
              "taskId",
              "graphKind",
              "primaryNodeId",
              "metadata"
            ],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "type": {"type": "string", "minLength": 1},
              "label": {"type": "string", "minLength": 1},
              "status": {"type": "string", "minLength": 1},
              "layer": {"type": "integer", "minimum": 0},
              "parentId": {"type": ["string", "null"]},
              "taskId": {"type": "string", "minLength": 1},
              "graphKind": {"type": "string", "minLength": 1},
              "primaryNodeId": {"type": "string", "minLength": 1},
              "metadata": {"type": "object", "additionalProperties": true}
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "source",
              "target",
              "type",
              "strength",
              "relationKind"
            ],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "source": {"type": "string", "minLength": 1},
              "target": {"type": "string", "minLength": 1},
              "type": {"type": "string", "minLength": 1},
              "strength": {"type": "number", "minimum": 0, "maximum": 1},
              "relationKind": {"type": "string", "minLength": 1}
            }
          }
        },
        "root_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "inspector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_node_id", "focused_nodes"],
      "properties": {
        "primary_node_id": {"type": ["string", "null"]},
        "focused_nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "node_id",
              "node_type",
              "label",
              "summary",
              "related_clip_ids",
              "related_source_paths"
            ],
            "properties": {
              "node_id": {"type": "string", "minLength": 1},
              "node_type": {"type": "string", "minLength": 1},
              "label": {"type": "string", "minLength": 1},
              "summary": {"type": "string", "minLength": 1},
              "related_clip_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "related_source_paths": {"type": "array", "items": {"type": "string", "minLength": 1}}
            }
          }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
