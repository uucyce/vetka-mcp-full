{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_time_marker_bundle_v1.schema.json",
  "title": "VETKA CUT Time Marker Bundle V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "timeline_id",
    "revision",
    "items",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cut_time_marker_bundle_v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "timeline_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "ranking_summary": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
