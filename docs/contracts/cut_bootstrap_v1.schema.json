{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_bootstrap_v1.schema.json",
  "title": "VETKA CUT Bootstrap V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "success",
    "schema_version",
    "degraded_mode",
    "degraded_reason"
  ],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "schema_version": {
      "type": "string",
      "const": "cut_bootstrap_v1"
    },
    "project": {
      "$ref": "cut_project_v1.schema.json"
    },
    "bootstrap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "state",
        "use_core_mirror",
        "core_mirror_root",
        "estimated_ready_sec"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["create_or_open", "open_existing", "create_new"]
        },
        "state": {
          "type": "string",
          "enum": ["ready", "queued", "running", "degraded", "error"]
        },
        "use_core_mirror": {
          "type": "boolean"
        },
        "core_mirror_root": {
          "type": "string",
          "minLength": 1
        },
        "estimated_ready_sec": {
          "type": "number",
          "minimum": 0
        },
        "job_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "media_files": {"type": "integer", "minimum": 0},
        "video_files": {"type": "integer", "minimum": 0},
        "audio_files": {"type": "integer", "minimum": 0},
        "image_files": {"type": "integer", "minimum": 0},
        "doc_files": {"type": "integer", "minimum": 0}
      }
    },
    "missing_inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "script_or_treatment": {"type": "boolean"},
        "montage_sheet": {"type": "boolean"},
        "transcript_or_timecodes": {"type": "boolean"}
      }
    },
    "fallback_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "priority", "question", "prefill"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "priority": {"type": "integer", "minimum": 1, "maximum": 10},
          "question": {"type": "string", "minLength": 1},
          "prefill": {"type": "string", "minLength": 1}
        }
      }
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "status", "progress"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["queued", "running", "done", "ready", "error"]},
          "progress": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "recoverable"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "message": {"type": "string", "minLength": 1},
        "recoverable": {"type": "boolean"}
      }
    },
    "degraded_mode": {
      "type": "boolean"
    },
    "degraded_reason": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "success": {"const": true}
        }
      },
      "then": {
        "required": [
          "project",
          "bootstrap",
          "stats",
          "missing_inputs",
          "fallback_questions",
          "phases",
          "next_actions"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "success": {"const": false}
        }
      },
      "then": {
        "required": ["error"]
      }
    }
  ]
}
