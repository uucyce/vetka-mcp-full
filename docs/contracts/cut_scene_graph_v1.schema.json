{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_scene_graph_v1.schema.json",
  "title": "VETKA CUT Scene Graph V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "graph_id",
    "revision",
    "nodes",
    "edges",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cut_scene_graph_v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "node_type", "label", "metadata"],
        "properties": {
          "node_id": {"type": "string", "minLength": 1},
          "node_type": {
            "type": "string",
            "enum": ["scene", "take", "asset", "note"]
          },
          "label": {"type": "string", "minLength": 1},
          "record_ref": {"type": ["string", "null"]},
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["edge_id", "edge_type", "source", "target", "weight"],
        "properties": {
          "edge_id": {"type": "string", "minLength": 1},
          "edge_type": {
            "type": "string",
            "enum": ["contains", "follows", "semantic_match", "alt_take", "references"]
          },
          "source": {"type": "string", "minLength": 1},
          "target": {"type": "string", "minLength": 1},
          "weight": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
