{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_audio_sync_result_v1.schema.json",
  "title": "VETKA CUT Audio Sync Result V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "revision",
    "items",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cut_audio_sync_result_v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "reference_path",
          "source_path",
          "detected_offset_sec",
          "confidence",
          "method",
          "refinement_steps",
          "peak_value",
          "degraded_mode",
          "degraded_reason"
        ],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "reference_path": { "type": "string", "minLength": 1 },
          "source_path": { "type": "string", "minLength": 1 },
          "detected_offset_sec": { "type": "number" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "method": {
            "type": "string",
            "enum": [
              "peak_only_v1",
              "correlation_v1",
              "peaks+correlation_v1"
            ]
          },
          "refinement_steps": { "type": "integer", "minimum": 1 },
          "peak_value": { "type": "number" },
          "degraded_mode": { "type": "boolean" },
          "degraded_reason": { "type": "string" }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
