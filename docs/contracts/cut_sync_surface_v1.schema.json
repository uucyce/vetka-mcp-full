{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cut_sync_surface_v1.schema.json",
  "title": "VETKA CUT Sync Surface V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "items",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cut_sync_surface_v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "source_path",
          "reference_path",
          "recommended_method",
          "recommended_offset_sec",
          "confidence"
        ],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "source_path": { "type": "string", "minLength": 1 },
          "reference_path": { "type": "string", "minLength": 1 },
          "timecode": { "type": ["object", "null"] },
          "waveform": { "type": ["object", "null"] },
          "meta_sync": { "type": ["object", "null"] },
          "recommended_method": {
            "type": ["string", "null"],
            "enum": ["timecode", "waveform", "meta_sync", null]
          },
          "recommended_offset_sec": { "type": "number" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
