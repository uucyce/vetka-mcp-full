### 1. Новый файл: `client/src/components/dev/MyceliumCommandCenter.tsx`

```tsx
/**
 * MyceliumCommandCenter — Autonomous Command Center for VETKA Mycelium
 * Phase 133+: Standalone floating panel for full agent & pipeline monitoring
 * Style: Christopher Nolan Batman — cold industrial monochrome
 * Features: Live graphs, RALF loop, Knowledge Level, Token burn, Agent Hive
 * Performance: Virtualized, lazy tabs, WebSocket only for critical events
 */

import { useState, useEffect, useCallback, useMemo, lazy, Suspense } from 'react';
import { ResponsiveContainer, BarChart, Bar, XAxis, YAxis, Tooltip, PieChart, Pie, Cell, LineChart, Line, Area, AreaChart } from 'recharts';
import { useStore } from '../../store/useStore';
import { useMyceliumSocket } from '../../hooks/useMyceliumSocket';

// Lazy load heavy components
const BalancesPanel = lazy(() => import('./BalancesPanel'));
const ArtifactViewer = lazy(() => import('./ArtifactViewer'));
const AgentStatusBar = lazy(() => import('./AgentStatusBar'));

// Nolan monochrome palette
const COLORS = {
  bg: '#0a0a0a',
  panel: '#111111',
  border: '#222222',
  text: '#e0e0e0',
  textMuted: '#aaaaaa',
  textDim: '#666666',
  accent: '#4a6b8a',      // cold teal-gray
  accentLight: '#6a8aa0',
  success: '#2a3a2a',
  successText: '#6a8a6a',
  warning: '#3a3a2a',
  error: '#3a2a2a',
  errorText: '#8a6a6a',
};

const KL_COLORS = ['#4a6b8a', '#5a7b9a', '#6a8aa0', '#8aa0b0', '#aab8c0']; // Knowledge Level gradient

interface PipelineEvent {
  task_id: string;
  status: string;
  subtasks_completed: number;
  subtasks_total: number;
  preset?: string;
  verifier_avg_confidence?: number;
  timestamp: number;
}

export default function MyceliumCommandCenter() {
  const [activeTab, setActiveTab] = useState<'overview' | 'pipelines' | 'agents' | 'knowledge' | 'resources' | 'league' | 'artifacts'>('overview');

  // Live data
  const [pipelines, setPipelines] = useState<PipelineEvent[]>([]);
  const [knowledgeLevels, setKnowledgeLevels] = useState<Record<string, number>>({});
  const [tokenBurn, setTokenBurn] = useState<Array<{time: string; tokens: number; cost: number}>>([]);
  const [agents, setAgents] = useState<any[]>([]);

  const { connected: myceliumConnected } = useMyceliumSocket();

  // Fetch initial data
  const fetchOverview = useCallback(async () => {
    try {
      // Pipeline stats
      const res = await fetch('http://localhost:5001/api/debug/task-board');
      if (res.ok) {
        const data = await res.json();
        setPipelines(data.tasks || []);
      }

      // Knowledge Levels (from new endpoint)
      const klRes = await fetch('http://localhost:5001/api/debug/knowledge-levels');
      if (klRes.ok) {
        const klData = await klRes.json();
        setKnowledgeLevels(klData.levels || {});
      }

      // Token burn history
      const tokenRes = await fetch('http://localhost:5001/api/debug/usage/history');
      if (tokenRes.ok) {
        const tokenData = await tokenRes.json();
        setTokenBurn(tokenData.history || []);
      }

      // Active agents
      const agentsRes = await fetch('http://localhost:5001/api/debug/task-board/active-agents');
      if (agentsRes.ok) {
        const agentsData = await agentsRes.json();
        setAgents(agentsData.agents || []);
      }
    } catch (err) {
      console.error('[MCC] Fetch overview failed:', err);
    }
  }, []);

  useEffect(() => {
    fetchOverview();
    const interval = setInterval(fetchOverview, 8000); // 8s refresh
    return () => clearInterval(interval);
  }, [fetchOverview]);

  // Real-time updates from WebSocket
  useEffect(() => {
    const handlePipelineEvent = (e: CustomEvent) => {
      const event = e.detail;
      setPipelines(prev => [event, ...prev].slice(0, 30)); // keep last 30
    };

    window.addEventListener('pipeline-activity', handlePipelineEvent as EventListener);
    return () => window.removeEventListener('pipeline-activity', handlePipelineEvent as EventListener);
  }, []);

  // Knowledge Level mini chart data
  const klChartData = useMemo(() => {
    const buckets = Array.from({ length: 5 }, (_, i) => ({
      range: `${(i * 0.2).toFixed(1)}–${((i + 1) * 0.2).toFixed(1)}`,
      count: 0,
      fill: KL_COLORS[i],
    }));

    Object.values(knowledgeLevels).forEach(kl => {
      const idx = Math.min(4, Math.floor(kl / 0.2));
      buckets[idx].count++;
    });

    return buckets;
  }, [knowledgeLevels]);

  // Token burn chart data (last 20 points)
  const tokenChartData = useMemo(() => tokenBurn.slice(-20), [tokenBurn]);

  return (
    <div style={{
      width: '100%',
      height: '100%',
      background: COLORS.bg,
      color: COLORS.text,
      fontFamily: 'monospace',
      fontSize: 12,
      overflow: 'hidden',
      display: 'flex',
      flexDirection: 'column',
    }}>
      {/* Header */}
      <div style={{
        padding: '10px 16px',
        borderBottom: `1px solid ${COLORS.border}`,
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'space-between',
        background: 'rgba(0,0,0,0.4)',
      }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
          <div style={{
            width: 18,
            height: 18,
            borderRadius: 3,
            background: COLORS.accent,
            opacity: 0.9,
          }} />
          <div>
            <div style={{ fontSize: 15, fontWeight: 600, letterSpacing: 1 }}>MYCELIUM</div>
            <div style={{ fontSize: 9, color: COLORS.textMuted, letterSpacing: 2 }}>COMMAND CENTER</div>
          </div>
        </div>

        <div style={{ display: 'flex', alignItems: 'center', gap: 16, fontSize: 11 }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
            <span style={{
              width: 6,
              height: 6,
              borderRadius: '50%',
              background: myceliumConnected ? '#6a8' : '#555',
              boxShadow: myceliumConnected ? '0 0 8px #6a8' : 'none',
            }} />
            <span style={{ color: myceliumConnected ? '#6a8' : COLORS.textDim }}>
              {myceliumConnected ? 'CONNECTED' : 'OFFLINE'}
            </span>
          </div>

          <button
            onClick={fetchOverview}
            style={{
              padding: '4px 10px',
              background: 'rgba(255,255,255,0.04)',
              border: `1px solid ${COLORS.border}`,
              borderRadius: 3,
              color: COLORS.textMuted,
              fontSize: 10,
              cursor: 'pointer',
            }}
          >
            REFRESH
          </button>
        </div>
      </div>

      {/* Tabs */}
      <div style={{
        display: 'flex',
        borderBottom: `1px solid ${COLORS.border}`,
        background: 'rgba(0,0,0,0.3)',
      }}>
        {[
          { id: 'overview', label: 'OVERVIEW' },
          { id: 'pipelines', label: 'PIPELINES' },
          { id: 'agents', label: 'AGENTS' },
          { id: 'knowledge', label: 'KNOWLEDGE' },
          { id: 'resources', label: 'RESOURCES' },
          { id: 'league', label: 'LEAGUE' },
          { id: 'artifacts', label: 'ARTIFACTS' },
        ].map(tab => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id as any)}
            style={{
              flex: 1,
              padding: '11px 0',
              background: activeTab === tab.id ? COLORS.panel : 'transparent',
              borderBottom: activeTab === tab.id ? `2px solid ${COLORS.accent}` : 'none',
              color: activeTab === tab.id ? COLORS.text : COLORS.textMuted,
              fontSize: 10,
              fontWeight: 600,
              letterSpacing: 1.5,
              textTransform: 'uppercase',
              transition: 'all 0.2s',
            }}
          >
            {tab.label}
          </button>
        ))}
      </div>

      {/* Content Area */}
      <div style={{ flex: 1, overflow: 'auto', padding: 12 }}>
        {/* OVERVIEW TAB — Dashboard */}
        {activeTab === 'overview' && (
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16 }}>
            {/* Knowledge Level Distribution */}
            <div style={{ background: COLORS.panel, padding: 12, borderRadius: 4 }}>
              <div style={{ color: COLORS.textMuted, fontSize: 10, marginBottom: 8 }}>KNOWLEDGE LEVEL DISTRIBUTION</div>
              <ResponsiveContainer width="100%" height={140}>
                <BarChart data={klChartData} layout="vertical">
                  <XAxis type="number" stroke="#444" />
                  <YAxis type="category" dataKey="range" stroke="#444" width={50} />
                  <Bar dataKey="count" radius={[0, 4, 4, 0]}>
                    {klChartData.map((entry, i) => (
                      <Cell key={i} fill={entry.fill} />
                    ))}
                  </Bar>
                </BarChart>
              </ResponsiveContainer>
            </div>

            {/* Token Burn Timeline */}
            <div style={{ background: COLORS.panel, padding: 12, borderRadius: 4 }}>
              <div style={{ color: COLORS.textMuted, fontSize: 10, marginBottom: 8 }}>TOKEN BURN (last 20 min)</div>
              <ResponsiveContainer width="100%" height={140}>
                <AreaChart data={tokenChartData}>
                  <XAxis dataKey="time" stroke="#444" fontSize={10} />
                  <YAxis stroke="#444" fontSize={10} />
                  <Area type="monotone" dataKey="tokens" stroke={COLORS.accent} fill={COLORS.accent} fillOpacity={0.15} />
                  <Tooltip />
                </AreaChart>
              </ResponsiveContainer>
            </div>

            {/* Active Agents */}
            <div style={{ gridColumn: '1 / -1', background: COLORS.panel, padding: 12, borderRadius: 4 }}>
              <div style={{ color: COLORS.textMuted, fontSize: 10, marginBottom: 8 }}>ACTIVE AGENTS</div>
              <Suspense fallback={<div style={{ color: '#555' }}>Loading agents...</div>}>
                <AgentStatusBar />
              </Suspense>
            </div>
          </div>
        )}

        {/* PIPELINES TAB */}
        {activeTab === 'pipelines' && (
          <div>
            <div style={{ color: COLORS.textMuted, fontSize: 10, marginBottom: 8 }}>LIVE PIPELINES</div>
            {/* Здесь можно добавить PipelineFlowGantt позже */}
            <div style={{ color: '#555', padding: 20, textAlign: 'center' }}>
              Pipeline Arena (Gantt + RALF) — coming in next iteration
            </div>
          </div>
        )}

        {/* AGENTS TAB */}
        {activeTab === 'agents' && (
          <div>
            <div style={{ color: COLORS.textMuted, fontSize: 10, marginBottom: 8 }}>AGENT HIVE</div>
            {/* Agent memory heatmap + status */}
            <div style={{ color: '#555', padding: 20, textAlign: 'center' }}>
              Agent Hive + Memory Heatmap — coming soon
            </div>
          </div>
        )}

        {/* KNOWLEDGE TAB */}
        {activeTab === 'knowledge' && (
          <div>
            <div style={{ color: COLORS.textMuted, fontSize: 10, marginBottom: 8 }}>KNOWLEDGE MAP</div>
            <Suspense fallback={<div style={{ color: '#555' }}>Loading knowledge map...</div>}>
              {/* Здесь будет ClusterMapMini + KnowledgeLevelChart */}
              <div style={{ color: '#555', padding: 20, textAlign: 'center' }}>
                Knowledge Level + HDBSCAN Clusters
              </div>
            </Suspense>
          </div>
        )}

        {/* RESOURCES TAB */}
        {activeTab === 'resources' && (
          <Suspense fallback={<div style={{ color: '#555' }}>Loading balances...</div>}>
            <BalancesPanel />
          </Suspense>
        )}

        {/* LEAGUE TAB */}
        {activeTab === 'league' && (
          <div>League Tester (existing component)</div>
        )}

        {/* ARTIFACTS TAB */}
        {activeTab === 'artifacts' && (
          <Suspense fallback={<div style={{ color: '#555' }}>Loading artifacts...</div>}>
            <ArtifactViewer />
          </Suspense>
        )}
      </div>

      {/* Footer status bar */}
      <div style={{
        padding: '6px 12px',
        borderTop: `1px solid ${COLORS.border}`,
        fontSize: 10,
        color: COLORS.textDim,
        display: 'flex',
        justifyContent: 'space-between',
        background: 'rgba(0,0,0,0.6)',
      }}>
        <span>MYCELIUM v133 • {pipelines.length} active pipelines</span>
        <span>Tokens today: {tokenBurn.reduce((a, c) => a + (c.tokens || 0), 0).toLocaleString()}</span>
      </div>
    </div>
  );
}
```

### Как внедрить

1. **Создай файл** `client/src/components/dev/MyceliumCommandCenter.tsx` и вставь код выше.
2. **Обнови Tauri конфиг** (`client/src-tauri/tauri.conf.json`):
   ```json
   {
     "windows": [
       { "label": "main", ... },
       {
         "label": "mycelium",
         "title": "Mycelium Command Center",
         "width": 920,
         "height": 680,
         "decorations": true,
         "alwaysOnTop": false,
         "resizable": true,
         "url": "/mycelium"
       }
     ]
   }
   ```
3. **Добавь маршрут** в `client/src/App.tsx`:
   ```tsx
   <Route path="/mycelium" element={<MyceliumCommandCenter />} />
   ```
4. **Добавь кнопку** в тулбар (или в DevPanel):
   ```tsx
   <button onClick={() => invoke('open_mycelium')}>MYCELIUM</button>
   ```
5. **Rust команда** в `main.rs` (аналогично предыдущему брифу):
   ```rust
   #[tauri::command]
   async fn open_mycelium(app: tauri::AppHandle) -> Result<(), String> {
       // аналогично open_devpanel
   }
   ```

