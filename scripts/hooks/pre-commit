#!/bin/bash
# Pre-commit hook: Auto-update project digest before each commit
#
# MARKER_142.FIX: This is the SINGLE authoritative place for digest updates.
# git_tool.py does only a lightweight patch after commit.
# MARKER_188.1: Skip digest update in worktrees (file not in worktree index).
# MARKER_200.NEVER_STAGE: Block CLAUDE.md from being committed (generated artifact).

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$(dirname "$SCRIPT_DIR")")"

# --- MARKER_200.NEVER_STAGE: Block generated artifacts BEFORE anything else ---
# CLAUDE.md is auto-generated by generate_claude_md.py on every session_init.
# It must NEVER be committed. This guard runs for BOTH main repo and worktrees.
BLOCKED_FILES="CLAUDE.md .agent_lock"
for BLOCKED in $BLOCKED_FILES; do
    if git diff --cached --name-only | grep -q "^${BLOCKED}$"; then
        echo "ERROR: ${BLOCKED} is a generated artifact — do not commit."
        echo "Run: git reset HEAD ${BLOCKED}"
        exit 1
    fi
done

# --- MARKER_188.1: Worktree detection ---
# In worktrees, git-dir != git-common-dir. Digest lives in main
# repo only — staging it from a worktree fails silently and wastes time.
GIT_DIR="$(git rev-parse --git-dir 2>/dev/null)"
GIT_COMMON="$(git rev-parse --git-common-dir 2>/dev/null)"
IS_WORKTREE=false
if [ -n "$GIT_DIR" ] && [ -n "$GIT_COMMON" ] && [ "$GIT_DIR" != "$GIT_COMMON" ]; then
    IS_WORKTREE=true
fi

if [ "$IS_WORKTREE" = true ]; then
    # Worktree: skip digest updates (they live in main repo)
    exit 0
fi

# --- Main repo only below this line ---

# Check if update script exists
UPDATE_SCRIPT="$PROJECT_ROOT/scripts/update_project_digest.py"

if [ -f "$UPDATE_SCRIPT" ]; then
    echo "Updating project digest..."

    # Run update script — use project venv for dependencies (requests, etc.)
    VENV_PYTHON="$PROJECT_ROOT/.venv/bin/python3"
    [ -x "$VENV_PYTHON" ] || VENV_PYTHON="python3"
    if "$VENV_PYTHON" "$UPDATE_SCRIPT" 2>&1; then
        git add data/project_digest.json 2>/dev/null || true
        echo "Project digest updated and staged."
    else
        echo "⚠️  Digest update failed (non-critical, continuing commit)"
    fi
fi

exit 0
