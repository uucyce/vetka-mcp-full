{
  "name": "vetka-photo-parallax-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 14350 --strictPort",
    "dev:stop": "sh ./scripts/dev-server-stop.sh",
    "dev:clean": "npm run dev:stop && vite --host 127.0.0.1 --port 14350 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^28.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^4.0.18"
  }
}
