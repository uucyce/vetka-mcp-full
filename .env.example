# VETKA Phase 7.9 + 8.0 - Learner Configuration
# Copy this file to .env and customize

# ============================================
# LEARNER CONFIGURATION (Phase 7.9)
# ============================================

# Choose learner type: "pixtral" or "qwen" (default: qwen)
# - pixtral: Multimodal, vision-enabled, 12B parameters, local via transformers
# - qwen: Text-only, fast, 7B parameters, via Ollama
LEARNER_TYPE=qwen

# Pixtral configuration (if LEARNER_TYPE=pixtral)
PIXTRAL_PATH=~/pixtral-12b

# Qwen configuration (if LEARNER_TYPE=qwen)
QWEN_MODEL=qwen2:7b

# ============================================
# LEARNER INITIALIZER (Phase 8.0 - HYBRID)
# ============================================

# 🖥️  LOCAL MODELS (Ollama - for inference)
# DeepSeek-V3.2-7B (Sparse attention, main workhorse)
DEEPSEEK_MODEL=deepseek-v3.2:7b

# HOPE-VL-7B (Hierarchical reasoning, vision)
HOPE_MODEL=hope-vl:7b-instruct-q4_k_m

# Qwen2-7B (already configured above, fast fallback)
# QWEN_MODEL=qwen2:7b

# ☁️  API MODELS (Cloud - for teaching/distillation)
# Grok-4 via xAI (best reasoning, teacher model)
GROK_API_KEY=your_xai_api_key_here

# Claude 3.5 Sonnet via Anthropic (code/structure expert)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GPT-4o-mini via OpenAI (fast, cheap distillation)
OPENAI_API_KEY=your_openai_api_key_here

# Advanced: Routing preferences (optional)
# PREFER_API=false           # Set true to prefer API models
# DEFAULT_COMPLEXITY=medium  # simple, medium, complex, expert

# ============================================
# QDRANT CONFIGURATION
# ============================================

# Qdrant host (auto-detected if not set)
# Options: 127.0.0.1 (local), host.docker.internal (Mac Docker)
# QDRANT_HOST=127.0.0.1

# ============================================
# EXAMPLE CONFIGURATIONS
# ============================================

# Example 1: Use Pixtral with vision capabilities
# LEARNER_TYPE=pixtral
# PIXTRAL_PATH=/path/to/pixtral-12b

# Example 2: Use Qwen for fast, reliable learning
# LEARNER_TYPE=qwen
# QWEN_MODEL=qwen2:7b

# Example 3: Use different Qwen variant
# LEARNER_TYPE=qwen
# QWEN_MODEL=qwen2:14b

# ============================================
# ADDING NEW LEARNERS
# ============================================

# To add a new learner (e.g., Claude, GPT-4):
# 1. Create src/agents/new_learner.py
# 2. Implement BaseLearner interface
# 3. Register with @LearnerFactory.register("name")
# 4. Add configuration here:
#    NEW_LEARNER_API_KEY=your_api_key
# 5. Update LEARNER_CONFIG in main.py
# 6. Switch with: curl -X POST http://localhost:5001/api/learner/switch -d '{"type":"name"}'
